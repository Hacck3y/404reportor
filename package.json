{
  "name": "recon-report",
  "version": "1.0.0",
  "description": "AI-assisted CLI that turns raw cybersecurity notes and screenshots into professional reports.",
  "type": "module",
  "bin": {
    "recon-report": "./bin/recon-report.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "smoke": "node ./bin/recon-report.js --help",
    "demo": "node ./bin/recon-report.js run --no-ai --input project_idea.md --format html"
  },
  "keywords": [
    "cybersecurity",
    "pentest",
    "ctf",
    "oscp",
    "report",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "dotenv": "^17.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^16.0.0",
    "ora": "^8.2.0",
    "puppeteer": "^24.12.1",
    "sharp": "^0.34.2"
  }
}
